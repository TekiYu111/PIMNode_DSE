from mapping_builder import MappingBuilder
from tests.helpers import collect_actions


def test_decode_end_to_end(decode_dag, placement_templates, builder_config):
    from fusion_gene import FusionGene, OpFusionGroup, FusionStyle
    from tilling_gene import TilingGene, GroupTilingSpec, MemTileSpec

    fusion = FusionGene(
        gene_id="decode_fusion",
        groups=[
            OpFusionGroup(
                group_id="g0",
                op_names=["Op_QK", "Op_Softmax", "Op_AV", "Op_O"],
                fusion_style=FusionStyle.SEQUENTIAL,
                phase="decode",
                special_role="KV_CACHE",
            )
        ],
    )

    tiling = TilingGene()
    tiling.add_group_spec(
        GroupTilingSpec(
            group_id="g0",
            tiles={
                "DRAM": MemTileSpec("DRAM", {"Sq": 1, "Skv": 128, "Dh": 64}, ["Skv", "Dh"]),
                "SRAM": MemTileSpec("SRAM", {"Sq": 1, "Skv": 64, "Dh": 64}, ["Skv", "Dh"]),
            },
            phase="decode",
            special_role="KV_CACHE",
        )
    )

    builder = MappingBuilder(
        dag=decode_dag,
        fusion=fusion,
        tiling=tiling,
        placement_plan=placement_templates,
        selected_templates={"g0": "K-D Fusion"},
        config=builder_config,
    )
    result = builder.build("decode")

    actions = collect_actions(result.tree)
    assert len(actions) > 0

    # decode 下不应对 KV cache 出现明显错误 writeback/evict
    bad = []
    for a in actions:
        if any("K" in t or "V" in t for t in a.tensors):
            if a.action_type in {"WRITEBACK", "WRITEBACK_DRAM", "EVICT"}:
                bad.append(a)
    assert not bad
